{
  "color": {
    "$type": "color",
    "background":         { "$value": "oklch(99% 0.01 80)" },
    "foreground":         { "$value": "oklch(18% 0.03 270)" },
    "card":               { "$value": "oklch(100% 0 0)" },
    "card-foreground":    { "$value": "oklch(18% 0.03 270)" },
    "primary":            { "$value": "oklch(58% 0.23 25)" },
    "primary-foreground": { "$value": "oklch(99% 0.01 80)" },
    "muted":              { "$value": "oklch(95% 0.03 80)" },
    "muted-foreground":   { "$value": "oklch(44% 0.04 270)" },
    "accent":             { "$value": "oklch(72% 0.19 85)" },
    "accent-foreground":  { "$value": "oklch(18% 0.03 270)" },
    "border":             { "$value": "oklch(88% 0.03 80)" },
    "input":              { "$value": "oklch(88% 0.03 80)" },
    "ring":               { "$value": "oklch(58% 0.23 25)" }
  },
  "spacing": {
    "$type": "dimension",
    "xs": { "$value": "4px" },
    "sm": { "$value": "8px" },
    "md": { "$value": "16px" },
    "lg": { "$value": "24px" },
    "xl": { "$value": "32px" }
  },
  "radius": {
    "$type": "dimension",
    "sm": { "$value": "6px" },
    "md": { "$value": "8px" },
    "lg": { "$value": "12px" }
  },
  "shadow": {
    "$type": "shadow",
    "sm": { "$value": "0 1px 2px 0 rgb(0 0 0 / 0.05)" },
    "md": { "$value": "0 4px 6px -1px rgb(0 0 0 / 0.1)" }
  }
}
